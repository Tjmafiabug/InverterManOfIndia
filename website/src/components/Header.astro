---
interface Props {
  activePage?: 'home' | 'news' | 'blog';
  bgColor?: string;
}

const { activePage = 'home', bgColor = 'transparent' } = Astro.props;
---

<header id="website-header" class="transition-colors duration-300" style={`position:relative;z-index:2000;background-color:${bgColor};color:rgb(255,255,255)`}>
  <div id="header-container" class="relative z-10 grid items-center lg:gap-6 xl:gap-10 mx-auto pt-6 pb-6 px-6 lg:px-12" style="grid-template-columns:auto auto auto">
    <div class="col-span-2 lg:col-span-1">
      <a class="grid max-w-full" href={import.meta.env.BASE_URL}>
        <h2 class="header-logo max-w-full whitespace-nowrap overflow-hidden overflow-ellipsis" style="color:rgb(255,255,255);font-family:'IBM Plex Sans',sans-serif;font-weight:600;line-height:initial;font-size:clamp(1rem,2vw,1.5rem);margin:0">invertermanofindia</h2>
      </a>
    </div>
    
    <div class="hidden lg:flex items-center justify-end gap-10 lg:col-span-2">
      <ul class="hidden items-center flex-wrap lg:flex justify-end gap-x-6" style="color:rgb(255,255,255)">
        <li class={`border-b-2 transition-colors ${activePage === 'home' ? 'border-white' : 'border-transparent hover:border-white'}`}>
          <a class="block whitespace-nowrap py-1.5 text-base" href={import.meta.env.BASE_URL}>Home</a>
        </li>
        <li class={`border-b-2 transition-colors ${activePage === 'news' ? 'border-white' : 'border-transparent hover:border-white'}`}>
          <a class="block whitespace-nowrap py-1.5 text-base" href={`${import.meta.env.BASE_URL}posts/news`}>News</a>
        </li>
        <li class={`border-b-2 transition-colors ${activePage === 'blog' ? 'border-white' : 'border-transparent hover:border-white'}`}>
          <a class="block whitespace-nowrap py-1.5 text-base" href={`${import.meta.env.BASE_URL}posts/blog`}>Blogs</a>
        </li>
      </ul>
      <div class="hidden lg:flex items-center flex-shrink-0 gap-4">
        <a href="mailto:invertermanofindia@gmail.com"
           style="border-width:2px;border-style:solid;background-color:rgb(0,116,255);color:rgb(255,255,255);border-radius:8px;border-color:rgb(0,116,255);font-weight:600;padding:10px 24px;font-size:1rem;display:inline-block;transition:all 0.2s ease-in-out;font-family:'IBM Plex Sans',sans-serif;">
          Contact us
        </a>
      </div>
    </div>

    <div class="ml-auto lg:hidden">
      <button id="mobile-menu-button" class="inline-flex items-center justify-center p-2 rounded-md focus:outline-none transition-opacity duration-300" style="color:rgb(255,255,255)">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-8 h-8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Drawer Backdrop -->
  <div id="drawer-backdrop" class="fixed inset-0 z-[2500] bg-black/60 opacity-0 pointer-events-none transition-opacity duration-300"></div>

  <!-- Mobile Drawer Panel (Right Side) -->
  <div id="mobile-drawer" class="fixed top-0 right-0 h-full w-[80%] max-w-[320px] z-[3000] translate-x-full transition-transform duration-300 ease-in-out shadow-2xl overflow-y-auto" style="background-color:rgb(19, 21, 22)">
    <div class="flex flex-col min-h-full text-white" style="background-color:rgb(19, 21, 22)">
      <div class="flex items-center justify-end px-6 py-6">
        <button id="close-drawer-button" class="p-4 text-zinc-400 hover:text-white bg-zinc-800/50 rounded-full" aria-label="Close menu">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      
      <nav class="flex flex-col py-2">
        <a href={import.meta.env.BASE_URL} class={`px-8 py-5 text-xl font-bold border-b ${activePage === 'home' ? 'text-blue-500 bg-white/5' : 'text-zinc-200'}`} style="border-color:rgba(255,255,255,0.05)">Home</a>
        <a href={`${import.meta.env.BASE_URL}posts/news`} class={`px-8 py-5 text-xl font-bold border-b ${activePage === 'news' ? 'text-blue-500 bg-white/5' : 'text-zinc-200'}`} style="border-color:rgba(255,255,255,0.05)">News</a>
        <a href={`${import.meta.env.BASE_URL}posts/blog`} class={`px-8 py-5 text-xl font-bold border-b ${activePage === 'blog' ? 'text-blue-500 bg-white/5' : 'text-zinc-200'}`} style="border-color:rgba(255,255,255,0.05)">Blogs</a>
      </nav>

      <div class="mt-8 px-6 pb-12">
        <a href="mailto:invertermanofindia@gmail.com" class="block w-full py-4 bg-blue-600 text-white font-bold rounded-xl text-center shadow-lg shadow-blue-900/40">
          Contact Us
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  function initDrawer() {
    const btn = document.getElementById('mobile-menu-button');
    const closeBtn = document.getElementById('close-drawer-button');
    const drawer = document.getElementById('mobile-drawer');
    const backdrop = document.getElementById('drawer-backdrop');

    if (!btn || !drawer || !backdrop || !closeBtn) return;

    function openDrawer(e) {
      if (e) e.preventDefault();
      drawer.classList.remove('translate-x-full');
      backdrop.classList.remove('opacity-0', 'pointer-events-none');
      btn.style.opacity = '0';
      btn.style.pointerEvents = 'none';
      // We don't lock body overflow if user wants to be able to "scroll" 
      // but usually we MUST lock it for a good drawer experience.
      // I'll keep it but ensure the DRAWER is scrollable.
      document.body.style.overflow = 'hidden';
    }

    function closeDrawer(e) {
      if (e) e.preventDefault();
      drawer.classList.add('translate-x-full');
      backdrop.classList.add('opacity-0', 'pointer-events-none');
      btn.style.opacity = '1';
      btn.style.pointerEvents = 'auto';
      document.body.style.overflow = '';
    }

    btn.onclick = openDrawer;
    closeBtn.onclick = closeDrawer;
    backdrop.onclick = closeDrawer;

    // Close on link click
    drawer.querySelectorAll('nav a').forEach(a => {
      a.onclick = closeDrawer;
    });
  }

  // Ensure it works on load and on layout swaps
  initDrawer();
  document.addEventListener('astro:after-swap', initDrawer);
</script>

<style>
  #mobile-drawer {
    box-shadow: -10px 0 30px rgba(0,0,0,0.8);
    opacity: 1 !important;
    /* Custom scrollbar for better look */
    scrollbar-width: none;
  }
  #mobile-drawer::-webkit-scrollbar {
    display: none;
  }
</style>
