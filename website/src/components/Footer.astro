---
---
<footer class="bg-zinc-950 border-t border-white/5 py-16 lg:py-24">
  <div class="container mx-auto px-6 lg:px-12">
    <div class="flex flex-col lg:flex-row justify-between items-start gap-16 lg:gap-24 mb-16">
      <div class="max-w-sm">
        <a href={import.meta.env.BASE_URL} class="inline-block mb-6">
          <h2 class="text-2xl font-bold tracking-tighter text-white">invertermanofindia</h2>
        </a>
        <p class="text-zinc-500 leading-relaxed mb-8">
          Dedicated to the legacy of Kunwer Sachdev and the future of India's power technology. Bringing expert insights into energy solutions.
        </p>
        <div class="flex items-center gap-5">
          <a href="https://linkedin.com/in/kunwwer-sachdev-9227381" target="_blank" class="w-10 h-10 rounded-full bg-zinc-900 flex items-center justify-center text-zinc-400 hover:bg-blue-600 hover:text-white transition-all transform hover:-translate-y-1">
             <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          </a>
          <a href="https://instagram.com/kunwersachdev/?hl=en" target="_blank" class="w-10 h-10 rounded-full bg-zinc-900 flex items-center justify-center text-zinc-400 hover:bg-pink-600 hover:text-white transition-all transform hover:-translate-y-1">
             <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <a href="https://facebook.com/kunwers" target="_blank" class="w-10 h-10 rounded-full bg-zinc-900 flex items-center justify-center text-zinc-400 hover:bg-blue-800 hover:text-white transition-all transform hover:-translate-y-1">
             <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22.675 0h-21.35c-.732 0-1.325.593-1.325 1.325v21.351c0 .731.593 1.324 1.325 1.324h11.495v-9.294h-3.128v-3.622h3.128v-2.671c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.463.099 2.795.143v3.24l-1.918.001c-1.504 0-1.795.715-1.795 1.763v2.313h3.587l-.467 3.622h-3.12v9.293h6.116c.73 0 1.323-.593 1.323-1.325v-21.35c0-.732-.593-1.325-1.325-1.325z"/></svg>
          </a>
        </div>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-3 gap-12 lg:gap-24 flex-1">
        <div class="flex flex-col gap-6">
          <h4 class="text-white font-bold uppercase tracking-widest text-xs">Resources</h4>
          <ul class="flex flex-col gap-4 text-zinc-500 text-sm">
            <li><a href="https://en.wikipedia.org/wiki/Kunwer_Sachdev" target="_blank" class="hover:text-white transition-colors">Wikipedia</a></li>
            <li><a href="https://kunwwer.ai/" target="_blank" class="hover:text-white transition-colors">Kunwwer.ai</a></li>
            <li><a href="https://kunwersachdev.com/" target="_blank" class="hover:text-white transition-colors">KunwerSachdev.com</a></li>
          </ul>
        </div>
        <div class="flex flex-col gap-6">
          <h4 class="text-white font-bold uppercase tracking-widest text-xs">Explore</h4>
          <ul class="flex flex-col gap-4 text-zinc-500 text-sm">
            <li><a href={import.meta.env.BASE_URL} class="hover:text-white transition-colors">Home</a></li>
            <li><a href={`${import.meta.env.BASE_URL}posts/news`} class="hover:text-white transition-colors">News</a></li>
            <li><a href={`${import.meta.env.BASE_URL}posts/blog`} class="hover:text-white transition-colors">Blogs</a></li>
          </ul>
        </div>
        <div class="flex flex-col gap-6 col-span-2 lg:col-span-1">
          <h4 class="text-white font-bold uppercase tracking-widest text-xs">Stay Connected</h4>
          <p class="text-zinc-500 text-sm leading-relaxed mb-4">Have questions about inverters or solar energy? Reach out to us.</p>
          <a href="mailto:invertermanofindia@gmail.com" class="inline-flex items-center gap-2 text-blue-500 font-bold hover:gap-4 transition-all">
            Email Kunwer
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </a>
        </div>
      </div>
    </div>

    <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6 text-zinc-600 text-[10px] uppercase font-bold tracking-widest">
      <p>© {new Date().getFullYear()} invertermanofindia. All rights reserved.</p>
      <div class="flex gap-8">
        <span class="hover:text-zinc-400 cursor-default opacity-50">Tribute Portfolio</span>
      </div>
    </div>
  </div>
</footer>
