---
import { ClientRouter } from 'astro:transitions';

interface Props {
	title: string;
	description?: string;
	image?: string;
  canonical?: string;
  bodyClass?: string;
}

const {
  title,
  description = "Invertermanofindia in Gurugram, Haryana offers expert advice, reviews, and guides on inverters for homes and businesses. Stay powered with our reliable support.",
  image = "https://cdn.durable.co/getty/25PZW8nDpD6pHCHd3MTR37prgUoE8b8My0VFqimBOH4MxQzwesus78LoJHjirp0w.jpeg",
  canonical = "https://invertermanofindia.com/",
  bodyClass = "overflow-x-hidden min-h-screen flex flex-col"
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth" style="--head-fontFamily: 'IBM Plex Sans', sans-serif; --head-fontWeight: 600; --head-fontStyle: normal; --body-fontFamily: 'Playfair Display', serif; --body-fontWeight: 400; --body-fontStyle: normal; --header-logo-fontFamily: 'IBM Plex Sans', sans-serif; --footer-logo-fontFamily: 'IBM Plex Sans', sans-serif; --header-logo-fontWeight: 600; --footer-logo-fontWeight: 600;">
	<head>
		<meta charset="utf-8"/>
		<meta name="viewport" content="width=device-width"/>
		<link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`}/><link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<title>{title}</title>
		<meta http-equiv="Content-Language" content="en"/>
    <meta name="title" property="og:title" content={title}/>
    <meta name="twitter:title" content={title}/>
    <meta property="og:type" content="website"/>
    <meta name="twitter:card" content="summary"/>
    <meta property="og:url" content={canonical}/>
    <meta name="description" property="og:description" content={description}/>
    <meta name="twitter:description" content={description}/>
    <meta name="image" property="og:image" content={image}/>
    <meta name="twitter:image" content={image}/>
    <meta name="google-site-verification" content="6k5HTueb9esPMpdY8siUkVf2Yc3D_oQUksJN0vNgzmU"/>
    <meta name="robots" content="all"/>
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="true"/>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@600;700;800&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet"/>
    <link rel="preload" href={`${import.meta.env.BASE_URL}css/main.css`} as="style"/>
    <link rel="stylesheet" href={`${import.meta.env.BASE_URL}css/main.css`}/>
    <link rel="preload" href={`${import.meta.env.BASE_URL}css/extra.css`} as="style"/>
    <link rel="stylesheet" href={`${import.meta.env.BASE_URL}css/extra.css`}/>
    
    <ClientRouter />

    <style is:global>
      #nprogress { pointer-events: none; }
      #nprogress .bar { background: #0074ff; position: fixed; z-index: 9999; top: 0; left: 0; width: 100%; height: 3px; }
      #nprogress .peg { display: block; position: absolute; right: 0px; width: 100px; height: 100%; box-shadow: 0 0 10px #0074ff, 0 0 5px #0074ff; opacity: 1; transform: rotate(3deg) translate(0px, -4px); }

      .heading-xlarge { font-size: clamp(2.5rem, 8vw, 6rem); font-weight: 800; line-height: 1; }
      .heading-large  { font-size: clamp(2rem, 5vw, 4rem);   font-weight: 800; line-height: 1.1; }
      .heading-medium { font-size: clamp(1.5rem, 3vw, 2.5rem); font-weight: 700; }
      .body-normal    { font-size: 1.125rem; font-family: var(--body-fontFamily); }
      
      .button { display: inline-block; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
      .button:hover { transform: translateY(-3px) scale(1.02); filter: brightness(1.1); }
      .button:active { transform: translateY(0) scale(0.98); }

      /* UX Enhancements */
      ::-webkit-scrollbar { width: 10px; }
      ::-webkit-scrollbar-track { background: #131516; }
      ::-webkit-scrollbar-thumb { background: #2a2d2f; border-radius: 5px; border: 2px solid #131516; }
      ::-webkit-scrollbar-thumb:hover { background: #3f4245; }

      .card-glow { transition: all 0.4s ease; border: 1px solid transparent; }
      .card-glow:hover { border-color: rgba(0, 116, 255, 0.3); box-shadow: 0 20px 40px -20px rgba(0, 116, 255, 0.2); transform: translateY(-8px); }

      img { color: transparent; }
      
      ::selection { background: rgba(0, 116, 255, 0.3); color: white; }

      .smooth-scroll { scroll-behavior: smooth; }
    </style>
	</head>
	<body class={bodyClass} style="background-color:rgb(19, 21, 22)">
		<slot />
	</body>
</html>
