---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
).slice(0, 3);
---

<BaseLayout title="Top Inverter Solutions by InverterMan in Gurugram, Haryana">
  <div id="__next" data-reactroot="">
    <div id="main-body" class="flex flex-col h-full overflow-y-auto overflow-x-hidden smooth-scroll transition-all">

      <Header activePage="home" bgColor="rgb(13,15,16)" />

      <!-- Spacer for Fixed Header -->
      <div class="h-[60px] lg:h-[70px]"></div>

      <!-- HERO SECTION: dark gradient overlay, background image, curve bottom -->
      <section class="relative">
        <div id="hero-section" data-text-color="#FFFFFF" class="flex relative break-word items-center fix-safari-flickering" style="z-index:39;min-height:calc(0px);padding-top:80px;padding-bottom:120px;clip-path:url('#hero-curveUp')">
          <div class="w-full flex break-word transition-all duration-300 items-center">
            <div class="absolute inset-0 z-10 pointer-events-none">
              <div class="absolute inset-0 z-10" style="background-image:linear-gradient(rgb(36,42,46),rgb(19,21,22));opacity:0.5"></div>
              <div class="absolute inset-0 z-0 bg-white">
                <span style="box-sizing:border-box;display:block;overflow:hidden;width:initial;height:initial;background:none;opacity:1;border:0;margin:0;padding:0;position:absolute;top:0;left:0;bottom:0;right:0">
                  <img alt="background" src={`${import.meta.env.BASE_URL}assets/hero.jpg`} style="position:absolute;top:0;left:0;bottom:0;right:0;box-sizing:border-box;padding:0;border:none;margin:auto;display:block;width:0;height:0;min-width:100%;max-width:100%;min-height:100%;max-height:100%;object-fit:cover;object-position:50% 15%"/>
                </span>
              </div>
            </div>
            <div class="relative z-10 container mx-auto px-5 md:px-6 transition-all duration-300 pt-12 lg:pt-20 pb-12 lg:pb-20">
              <div class="transition-all ease-in-out duration-500 opacity-100 translate-y-0 relative z-10 w-full h-full">
                <div class="flex w-full gap-10 lg:gap-20 transition-all duration-300 flex-col lg:flex-row justify-center">
                  <div class="flex-1 flex flex-col gap-4 w-full max-w-3xl items-center text-center mx-auto">
                    <h1 class="break-word heading-xlarge" style="color:rgb(255,255,255)">From Entrepreneur to Innovator</h1>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <svg class="absolute bottom-0 left-0" width="1470" height="659" viewBox="0 0 1470 659">
            <clipPath id="hero-curveUp">
              <rect width="1470" height="570" fill="transparent"></rect>
              <path d="M0 0 C735 89 735 89 1470 0 L1470 0 L0 0" transform="translate(0, 570)" fill="transparent"></path>
            </clipPath>
          </svg>
        </div>
      </section>

      <!-- ABOUT SECTION: dark bg #3f3f4f, white text, curve bottom -->
      <section class="relative">
        <div id="about-section" class="flex flex-none flex-shrink-0 relative break-word items-center fix-safari-flickering" style="min-height:calc(0px);z-index:38;margin-top:-100px;padding-top:150px;padding-bottom:200px;clip-path:url('#about-curveUp')">
          <div class="absolute inset-0 z-10 pointer-events-none">
            <div class="absolute inset-0 z-10" style="background-color:rgb(63,63,79)"></div>
          </div>
          <div class="relative z-10 container mx-auto pt-16 lg:pt-32 pb-16 lg:pb-32">
            <div class="transition-all ease-in-out duration-500 opacity-100 translate-y-0 flex w-full gap-10 lg:gap-20 flex-col-reverse justify-center">
              <div class="flex-1 flex flex-col max-w-240 items-center text-center mx-auto">
                <div class="rich-text-block" style="color:rgb(255,255,255)">
                  <h2 style="white-space:pre-line;text-align:center">A Vision Beyond Power – Remembering Kunwer Sachdev</h2>
                  <p>For over two decades, I had the rare privilege of walking beside a man who didn't just build a company — he built a movement.</p>
                  <p>This website is my heartfelt tribute to Kunwer Sachdev, the founder of Su-Kam — a name that once echoed across every household and street where power failed, but hope still burned bright.</p>
                  <p>I didn't just read about his journey — I lived it. I stood beside him through the chaos and creation, through late nights of relentless innovation and early mornings of impossible ideas turned real.</p>
                  <p>He was more than an entrepreneur. He was a disruptor of technology. A man who could look at what already existed — and reinvent it from the ground up.<br/>He didn't follow trends — he set them.<br/>He didn't just solve problems — he challenged the very way we think about them.</p>
                  <p>With Su-Kam, he redefined India's power backup industry. He didn't just build inverters — he built a brand that ran through homes, businesses, villages, and lives. 25 years of blood, sweat, and vision went into creating something that felt immortal.</p>
                  <p>But when he lost Su-Kam, what hurt most wasn't the fall of a company. It was watching a man lose something that was a part of his soul.<br/>It was a heartbreak only those closest to him could truly understand.</p>
                  <p>Yet true visionaries never stop.</p>
                  <p>Today, Kunwer Sachdev is once again building — this time at the frontiers of Artificial Intelligence, through his newest venture: Kunwwer.AI.<br/>With the same fire and clarity, he is now working to train the next generation, mentoring young minds, and leading India into an AI-powered future.<br/>And I know — as surely as I've known him for 20+ years — he will be a disruptor in this space too.</p>
                  <p>Because that's who Kunwer Sachdev is.<br/>A creator. A mentor. A storm in still air.<br/>A man who turns setbacks into revolutions.</p>
                  <p>I choose not to reveal my identity here — not out of secrecy, but out of deep respect.<br/>I work in the same industry as him, and every inch of who I am today — every value I carry, every success I've earned — I owe to him.<br/>His guidance shaped me, his vision fueled me, and his presence continues to inspire me, even from a distance.</p>
                  <p>This website is not just a tribute — it is a thank you, whispered into the winds of memory.<br/>A testament to what I saw with my own eyes.<br/>A promise to keep telling the world about the legend who changed my life, and the lives of countless others.<br/>💔 This is not a goodbye. This is a salute — to a life that never stopped building.<br/>— A silent witness to his brilliance, a student of his fire, and a keeper of his legacy.</p>
                </div>
              </div>
              <div class="flex-1 flex w-full h-full items-center lg:max-w-1/2 mx-auto text-center">
                <div class="flex-shrink-0 relative w-full h-full mx-auto aspect-w-16 aspect-h-9">
                  <span style="box-sizing:border-box;display:block;overflow:hidden;width:initial;height:initial;background:none;opacity:1;border:0;margin:0;padding:0;position:absolute;top:0;left:0;bottom:0;right:0">
                    <img alt="Kunwer Sachdev" src={`${import.meta.env.BASE_URL}assets/kunwer-portrait.png`} decoding="async" class="rounded-2xl md:rounded-3xl lg:rounded-4xl" style="position:absolute;top:0;left:0;bottom:0;right:0;box-sizing:border-box;padding:0;border:none;margin:auto;display:block;width:0;height:0;min-width:100%;max-width:100%;min-height:100%;max-height:100%;object-fit:cover;object-position:center center"/>
                  </span>
                </div>
              </div>
            </div>
          </div>
          <svg class="absolute bottom-0 left-0" width="1470" height="2242" viewBox="0 0 1470 2242">
            <clipPath id="about-curveUp">
              <rect width="1470" height="2153" fill="transparent"></rect>
              <path d="M0 0 C735 89 735 89 1470 0 L1470 0 L0 0" transform="translate(0, 2153)" fill="transparent"></path>
            </clipPath>
          </svg>
        </div>
      </section>

      <!-- RECENT POSTS SECTION: near-black bg -->
      <section class="relative">
        <div id="recent-posts-section" class="flex flex-none flex-shrink-0 relative break-word items-center" style="min-height:calc(0px);z-index:37;margin-top:-150px;padding-top:180px;padding-bottom:0px">
          <div class="absolute inset-0 z-10 pointer-events-none">
            <div class="absolute inset-0 z-10" style="background-color:rgb(19,21,22)"></div>
          </div>
          <div class="relative z-10 container mx-auto pt-16 lg:pt-24 pb-16 lg:pb-32">
            <div class="flex flex-col gap-4 mb-10 items-center text-center mx-auto">
              <h2 class="break-word heading-large" style="color:rgb(255,255,255)">Recent blog posts</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
              {posts.map((post, i) => (
                <a class="group" href={`${import.meta.env.BASE_URL}posts/blog/${post.id}`}>
                  <div class="transition-all ease-in-out duration-500" style={`transition-delay:${(i+1)*100}ms`}>
                    <div class="relative overflow-hidden mb-6 rounded-2xl md:rounded-3xl lg:rounded-4xl aspect-w-16 aspect-h-9 shadow-lg">
                      <img 
                        src={post.data.image?.url 
                          ? (post.data.image.url.startsWith('http') || post.data.image.url.startsWith(import.meta.env.BASE_URL)
                              ? post.data.image.url 
                              : `${import.meta.env.BASE_URL}${post.data.image.url.startsWith('/') ? post.data.image.url.slice(1) : post.data.image.url}`) 
                          : `${import.meta.env.BASE_URL}assets/default-blog.jpg`}
                        alt={post.data.title}
                        class="w-full h-full object-cover transition-all duration-300 group-hover:scale-110"
                      />
                    </div>
                    <div class="text-center">
                      <h3 class="heading-medium mb-2 group-hover:underline" style="color:rgb(255,255,255)">{post.data.title}</h3>
                      <p class="body-normal" style="color:rgb(255,255,255)">{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</p>
                    </div>
                  </div>
                </a>
              ))}
            </div>
            <div class="mt-6 lg:mt-10 text-center">
              <a class="button md" target="_self" style="border-width:2px;border-style:solid;box-shadow:none;font-family:var(--body-fontFamily);font-weight:var(--body-fontWeight,500);font-style:var(--body-fontStyle);background-color:transparent;color:rgb(255,255,255);border-radius:8px;border-color:rgb(255,255,255)" href={`${import.meta.env.BASE_URL}posts/blog`}>View more</a>
            </div>
          </div>
        </div>
      </section>

      <Footer />
    </div>
  </div>
</BaseLayout>
