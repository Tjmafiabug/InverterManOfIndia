---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
).slice(0, 3);
---

<BaseLayout title="Top Inverter Solutions by InverterMan in Gurugram, Haryana">
  <div id="__next" data-reactroot="">
    <div id="main-body" class="flex flex-col h-full overflow-y-auto overflow-x-hidden smooth-scroll transition-all">

      <Header activePage="home" bgColor="rgb(13,15,16)" />

      <!-- Spacer for Fixed Header -->
      <div class="h-[60px] lg:h-[70px]"></div>

      <!-- HERO SECTION -->
      <section class="relative">
        <div id="hero-section" data-text-color="#FFFFFF" class="flex relative break-word items-center fix-safari-flickering" style="z-index:39;min-height:calc(0px);padding-top:80px;padding-bottom:120px;clip-path:url('#hero-curveUp')">
          <div class="w-full flex break-word transition-all duration-300 items-center">
            <div class="absolute inset-0 z-10 pointer-events-none">
              <div class="absolute inset-0 z-10" style="background-image:linear-gradient(rgb(36,42,46),rgb(19,21,22));opacity:0.5"></div>
              <div class="absolute inset-0 z-0 bg-white">
                <span class="block overflow-hidden absolute inset-0">
                  <img alt="background" src={`${import.meta.env.BASE_URL}assets/hero.jpg`} class="absolute inset-0 w-full h-full object-cover object-[50%_15%]"/>
                </span>
              </div>
            </div>
            <div class="relative z-10 container mx-auto px-5 md:px-6 pt-12 lg:pt-20 pb-12 lg:pb-20">
              <div class="transition-all ease-in-out duration-700 opacity-100 translate-y-0 relative z-10 w-full h-full">
                <div class="flex w-full gap-10 lg:gap-20 transition-all duration-300 flex-col lg:flex-row justify-center">
                  <div class="flex-1 flex flex-col gap-4 w-full max-w-3xl items-center text-center mx-auto">
                    <h1 class="break-word heading-xlarge drop-shadow-2xl" style="color:rgb(255,255,255)">From Entrepreneur to Innovator</h1>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <svg class="absolute bottom-0 left-0" width="1470" height="659" viewBox="0 0 1470 659">
            <clipPath id="hero-curveUp">
              <rect width="1470" height="570" fill="transparent"></rect>
              <path d="M0 0 C735 89 735 89 1470 0 L1470 0 L0 0" transform="translate(0, 570)" fill="transparent"></path>
            </clipPath>
          </svg>
        </div>
      </section>

      <!-- ABOUT SECTION -->
      <section class="relative">
        <div id="about-section" class="flex flex-none flex-shrink-0 relative break-word items-center fix-safari-flickering" style="min-height:calc(0px);z-index:38;margin-top:-100px;padding-top:150px;padding-bottom:89px;clip-path:url('#about-curveUp')">
          <div class="absolute inset-0 z-10 pointer-events-none">
            <div class="absolute inset-0 z-10" style="background-color:rgb(63,63,79)"></div>
          </div>
          <div class="relative z-10 container mx-auto pt-16 lg:pt-32 pb-16 lg:pb-32">
            <div class="transition-all ease-in-out duration-700 opacity-100 translate-y-0 flex w-full gap-16 lg:gap-24 flex-col-reverse justify-center">
              <div class="flex-1 flex flex-col max-w-4xl items-center text-center mx-auto">
                <div class="rich-text-block space-y-6 text-lg leading-relaxed" style="color:rgb(255,255,255)">
                  <h2 class="heading-large mb-12">A Vision Beyond Power – Remembering Kunwer Sachdev</h2>
                  <p>For over two decades, I had the rare privilege of walking beside a man who didn't just build a company — he built a movement.</p>
                  <p>This website is my heartfelt tribute to Kunwer Sachdev, the founder of Su-Kam — a name that once echoed across every household and street where power failed, but hope still burned bright.</p>
                  <p>... Standing beside him through late nights of relentless innovation ...</p>
                  <p class="font-bold italic text-blue-300">"He didn't follow trends — he set them."</p>
                  <p>True visionaries never stop. Today, Kunwer Sachdev is once again building through his newest venture: <a href="https://kunwwer.ai" target="_blank" class="text-blue-400 underline hover:text-blue-300 transition-colors">Kunwwer.AI</a>.</p>
                  <p class="pt-8 border-t border-white/10 opacity-70 italic">— A silent witness to his brilliance, a student of his fire, and a keeper of his legacy.</p>
                </div>
              </div>
              <div class="flex-1 flex w-full h-full items-center lg:max-w-1/2 mx-auto text-center">
                <div class="flex-shrink-0 relative w-full h-full mx-auto aspect-w-16 aspect-h-9 group">
                  <img alt="Kunwer Sachdev" src="https://cdn.durable.co/getty/25PZW8nDpD6pHCHd3MTR37prgUoE8b8My0VFqimBOH4MxQzwesus78LoJHjirp0w.jpeg" class="rounded-2xl md:rounded-3xl lg:rounded-4xl object-cover shadow-2xl transition-transform duration-700 group-hover:scale-[1.03]"/>
                </div>
              </div>
            </div>
          </div>
          <svg class="absolute bottom-0 left-0" width="1470" height="2242" viewBox="0 0 1470 2242">
            <clipPath id="about-curveUp">
              <rect width="1470" height="2153" fill="transparent"></rect>
              <path d="M0 0 C735 89 735 89 1470 0 L1470 0 L0 0" transform="translate(0, 2153)" fill="transparent"></path>
            </clipPath>
          </svg>
        </div>
      </section>

      <!-- RECENT POSTS SECTION -->
      <section class="relative">
        <div id="recent-posts-section" class="flex flex-none flex-shrink-0 relative break-word items-center" style="min-height:calc(0px);z-index:37;margin-top:-90px;padding-top:90px;padding-bottom:0px">
          <div class="absolute inset-0 z-10 pointer-events-none">
            <div class="absolute inset-0 z-10" style="background-color:rgb(13,15,16)"></div>
          </div>
          <div class="relative z-10 container mx-auto pt-16 lg:pt-32 pb-16 lg:pb-32 px-6">
            <div class="flex flex-col gap-4 mb-16 items-center text-center mx-auto">
              <h2 class="heading-large underline decoration-blue-600 decoration-4 underline-offset-8" style="color:rgb(255,255,255)">Recent Discoveries</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 lg:gap-12">
              {posts.map((post, i) => (
                <a class="group card-glow flex flex-col bg-zinc-900/40 rounded-3xl overflow-hidden p-4 h-full" href={`${import.meta.env.BASE_URL}posts/blog/${post.id}`}>
                  <div class="relative overflow-hidden mb-6 rounded-2xl aspect-w-16 aspect-h-9">
                    <img 
                      src={post.data.image?.url 
                        ? (post.data.image.url.startsWith('http') || post.data.image.url.startsWith(import.meta.env.BASE_URL)
                            ? post.data.image.url 
                            : `${import.meta.env.BASE_URL}${post.data.image.url.startsWith('/') ? post.data.image.url.slice(1) : post.data.image.url}`) 
                        : `${import.meta.env.BASE_URL}assets/default-blog.jpg`}
                      alt={post.data.title}
                      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                    />
                  </div>
                  <div class="flex flex-col flex-1 px-2 pb-2">
                    <div class="flex items-center gap-2 mb-3">
                      <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
                      <p class="text-xs uppercase tracking-widest text-zinc-500 font-bold">{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</p>
                    </div>
                    <h3 class="heading-medium text-xl lg:text-2xl mb-4 group-hover:text-blue-400 transition-colors" style="color:rgb(255,255,255)">{post.data.title}</h3>
                    <div class="mt-auto flex items-center gap-2 text-blue-500 font-bold text-sm">
                      Read Full Story
                      <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                    </div>
                  </div>
                </a>
              ))}
            </div>
            <div class="mt-12 lg:mt-20 text-center">
              <a class="button md py-4 px-10 border-2 border-white rounded-xl font-bold text-white hover:bg-white hover:text-black transition-all" href={`${import.meta.env.BASE_URL}posts/blog`}>Explore All Articles</a>
            </div>
          </div>
        </div>
      </section>

      <Footer />
    </div>
  </div>
</BaseLayout>
