---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const imageUrl = post.data.image?.url 
  ? (post.data.image.url.startsWith('http') || post.data.image.url.startsWith(import.meta.env.BASE_URL)
      ? post.data.image.url 
      : `${import.meta.env.BASE_URL}${post.data.image.url.startsWith('/') ? post.data.image.url.slice(1) : post.data.image.url}`)
  : null;
---

<BaseLayout
  title={`${post.data.title} | Inverter Man Insights`}
  description={post.data.description}
  image={imageUrl || "https://cdn.durable.co/getty/25PZW8nDpD6pHCHd3MTR37prgUoE8b8My0VFqimBOH4MxQzwesus78LoJHjirp0w.jpeg"}
>

  <!-- ── HEADER ── -->
  <Header activePage="blog" bgColor="rgb(13,15,16)" />

  <!-- Spacer for Fixed Header -->
  <div class="h-[60px] lg:h-[70px]"></div>

  <!-- ── HERO ── -->
  <section class="relative w-full" style="min-height:420px">
    <!-- background image -->
    {imageUrl
      ? <img src={imageUrl} alt=""
             class="absolute inset-0 w-full h-full object-cover" aria-hidden="true" />
      : <div class="absolute inset-0" style="background:#242a2e"></div>
    }
    <!-- dark overlay -->
    <div class="absolute inset-0" style="background:rgba(13,17,20,0.68)"></div>
    <!-- text -->
    <div class="relative z-10 flex flex-col items-center justify-center text-center
                px-6 py-24 lg:py-32 min-h-[420px]">
      <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color:#2483e9">
        Blog Post
      </p>
      <h1 class="text-white font-bold leading-tight max-w-3xl"
          style="font-family:'IBM Plex Sans',sans-serif;font-size:clamp(1.75rem,4.5vw,3rem)">
        {post.data.title}
      </h1>
      <p class="mt-5 text-sm" style="color:rgba(255,255,255,0.55)">
        {new Date(post.data.pubDate).toLocaleDateString('en-US',
          { month: 'short', day: 'numeric', year: 'numeric' })}
        {post.data.author && <span> &nbsp;·&nbsp; {post.data.author}</span>}
      </p>
    </div>
  </section>

  <!-- ── ARTICLE ── -->
  <main class="bg-white">
    <div class="max-w-3xl mx-auto px-6 lg:px-8 py-14 lg:py-20">

      <!-- article title -->
      <h2 class="font-bold leading-snug mb-10"
          style="font-family:'IBM Plex Sans',sans-serif;
                 font-size:clamp(1.5rem,3.5vw,2.5rem);
                 color:#0f172a">
        {post.data.title}
      </h2>

      <!-- description / lede -->
      {post.data.description && (
        <p class="text-lg italic leading-relaxed mb-10 pb-10 border-b"
           style="font-family:'Playfair Display',serif;color:#475569;border-color:#e2e8f0">
          {post.data.description}
        </p>
      )}

      <!-- body -->
      <div class="article-content">
        <Content />
      </div>

    </div>
  </main>

  <Footer />

</BaseLayout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;600;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap');

  /* ── article body ── */
  .article-content {
    font-family: 'Playfair Display', serif;
    color: #1e293b;
  }
  .article-content p {
    font-size: 1.0625rem;
    line-height: 1.9;
    margin-bottom: 1.6rem;
    color: #1e293b;
  }
  .article-content h2 {
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 1.625rem;
    font-weight: 700;
    color: #0f172a;
    margin-top: 3rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }
  .article-content h3 {
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #0f172a;
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }
  .article-content ul,
  .article-content ol {
    padding-left: 1.5rem;
    margin-bottom: 1.6rem;
  }
  .article-content li {
    font-size: 1.0625rem;
    line-height: 1.8;
    margin-bottom: 0.4rem;
    color: #1e293b;
  }
  .article-content blockquote {
    border-left: 4px solid #0074ff;
    padding-left: 1.25rem;
    margin: 2.5rem 0;
    font-style: italic;
    color: #475569;
  }
  .article-content img {
    width: 100%;
    border-radius: 0.75rem;
    margin: 2rem 0;
  }
  .article-content strong { font-weight: 700; color: #0f172a; }
  .article-content a { color: #0074ff; text-decoration: underline; }
</style>
